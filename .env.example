# ═══════════════════════════════════════
# LONGENY — Environment Configuration
# ═══════════════════════════════════════
# Copy to .env and fill in values:
#   cp .env.example .env

# ── General ──
NODE_ENV=development
LOG_LEVEL=debug

# ── Gateway (Port 3000) ──
GATEWAY_PORT=3000

# ── Auth Service (Port 3001) ──
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_URL=http://localhost:3001
JWT_ACCESS_SECRET=change-me-generate-with-openssl-rand-hex-48
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-hex-48
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_SALT_ROUNDS=12
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── User & Provider Service (Port 3002) ──
USER_PROVIDER_SERVICE_PORT=3002
USER_PROVIDER_SERVICE_URL=http://localhost:3002

# ── Booking Service (Port 3003) ──
BOOKING_SERVICE_PORT=3003
BOOKING_SERVICE_URL=http://localhost:3003
GOOGLE_CALENDAR_CLIENT_ID=your-calendar-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-calendar-client-secret

# ── AI & Content Service (Port 3004) ──
AI_CONTENT_SERVICE_PORT=3004
AI_CONTENT_SERVICE_URL=http://localhost:3004
AWS_BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID_PRIMARY=meta.llama3-1-70b-instruct-v1:0
BEDROCK_MODEL_ID_LIGHT=meta.llama3-1-8b-instruct-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# ── Payment Service (Port 3005) ──
PAYMENT_SERVICE_PORT=3005
PAYMENT_SERVICE_URL=http://localhost:3005
PAYMENT_GATEWAY=stripe
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
RAZORPAY_KEY_ID=rzp_test_your-key
RAZORPAY_KEY_SECRET=your-secret

# ── PostgreSQL ──
POSTGRES_USER=longeny
POSTGRES_PASSWORD=longeny_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
AUTH_DATABASE_URL=postgresql://longeny:longeny_dev_password@localhost:5432/longeny_auth
CORE_DATABASE_URL=postgresql://longeny:longeny_dev_password@localhost:5432/longeny_core
BOOKING_DATABASE_URL=postgresql://longeny:longeny_dev_password@localhost:5432/longeny_bookings
AI_CONTENT_DATABASE_URL=postgresql://longeny:longeny_dev_password@localhost:5432/longeny_ai_content
PAYMENT_DATABASE_URL=postgresql://longeny:longeny_dev_password@localhost:5432/longeny_payments

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AWS / LocalStack ──
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_UPLOADS_BUCKET=longeny-uploads
S3_DOCUMENTS_BUCKET=longeny-documents

# ── Twilio / Email ──
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@longeny.com
SENDGRID_API_KEY=your-sendgrid-key

# ── Security ──
ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
HMAC_SECRET=generate-with-openssl-rand-hex-32
HMAC_TOLERANCE_SECONDS=30

# ── CORS ──
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
