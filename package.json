{
  "name": "longeny",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bunx turbo dev",
    "build": "bunx turbo build",
    "test": "bunx turbo test",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "format": "bunx biome format --write .",
    "db:generate": "bunx turbo db:generate",
    "db:migrate": "bunx turbo db:migrate",
    "db:seed": "bunx turbo db:seed",
    "db:push": "bunx turbo db:push",
    "db:studio": "bunx turbo db:studio",
    "clean": "bunx turbo clean && rm -rf node_modules",
    "typecheck": "bunx turbo typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.3.0",
    "bun-types": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "@sinclair/typebox": "^0.34.49"
  }
}
